								"value": "Bearer {{analystToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/dashboard/summary?from=2026-01-01&to=2026-12-31",
							"host": ["{{baseUrl}}"],
							"path": ["api", "dashboard", "summary"],
							"query": [
								{
									"key": "from",
									"value": "2026-01-01"
								},
								{
									"key": "to",
									"value": "2026-12-31"
								}
