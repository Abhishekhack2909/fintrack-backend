						],
						"url": {
							"raw": "{{baseUrl}}/api/dashboard/weekly",
							"host": ["{{baseUrl}}"],
							"path": ["api", "dashboard", "weekly"]
						}
					}
				}
			]
		},
		{
			"name": "Test Access Control",
			"item": [
				{
					"name": "Viewer Try Create Record (Should Fail)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{viewerToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 100,\n  \"type\": \"income\",\n  \"category\": \"Test\",\n  \"date\": \"2026-04-03\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/records",
							"host": ["{{baseUrl}}"],
							"path": ["api", "records"]
						}
					}
				},
				{
					"name": "Viewer Try Dashboard (Should Fail)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{viewerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/dashboard/summary",
							"host": ["{{baseUrl}}"],
							"path": ["api", "dashboard", "summary"]
						}
					}
				}
			]
		}
	]
}
